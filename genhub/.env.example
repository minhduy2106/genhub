# Public URLs used by frontend and backend.
# On local machine:
# FRONTEND_URL=http://localhost:3000
# BACKEND_PUBLIC_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
#
# On another machine in the same LAN:
# FRONTEND_URL=http://192.168.1.10:3000
# BACKEND_PUBLIC_URL=http://192.168.1.10:4000
# NEXT_PUBLIC_API_URL=http://192.168.1.10:4000/api/v1
#
# On a server/domain:
# FRONTEND_URL=https://app.example.com
# BACKEND_PUBLIC_URL=https://api.example.com
# NEXT_PUBLIC_API_URL=https://api.example.com/api/v1
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Bind ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Backend bind host
BACKEND_HOST=0.0.0.0

# Optional extra CORS origins, comma-separated.
# Example: http://192.168.1.20:3000,https://admin.example.com
CORS_ORIGINS=
