# Sinh secret riêng cho mỗi môi trường (tối thiểu 32 ký tự):
#   openssl rand -base64 48
JWT_SECRET=
POSTGRES_PASSWORD=genhub_secret

# URL frontend — chỉ cần đặt đúng IP/domain máy deploy để CORS hoạt động
# LAN:       FRONTEND_URL=http://192.168.1.10:3000
# Tailscale: FRONTEND_URL=http://100.x.x.x:3000
# Domain:    FRONTEND_URL=https://app.example.com
FRONTEND_URL=http://localhost:3000

# Để trống — frontend tự proxy /api/v1 và /uploads qua Next.js rewrites
BACKEND_PUBLIC_URL=

# Bind ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Backend bind host
BACKEND_HOST=0.0.0.0

# Optional extra CORS origins, comma-separated.
# Example: http://192.168.1.20:3000,https://admin.example.com
CORS_ORIGINS=

# Máy chủ OCR quét ảnh sản phẩm (app iOS-OCR-Server chạy trên iPhone, cổng 8000).
# Có thể override trong app: Cài đặt → Máy chủ OCR.
# Example: OCR_SERVER_URL=http://192.168.1.50:8000
OCR_SERVER_URL=
