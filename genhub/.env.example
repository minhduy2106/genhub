# Sinh secret riêng cho mỗi môi trường (tối thiểu 32 ký tự):
#   openssl rand -base64 48
JWT_SECRET=
POSTGRES_PASSWORD=change-me-in-production

# URL frontend dùng cho CORS/cookie khi deploy.
# Local:  FRONTEND_URL=http://localhost:3000
# Domain: FRONTEND_URL=https://app.example.com
FRONTEND_URL=http://localhost:3000

# Để trống khi dùng frontend Next.js proxy /api/v1 và /uploads.
BACKEND_PUBLIC_URL=
CORS_ORIGINS=

# Bind public app port, giữ backend/database/cache ở localhost mặc định.
FRONTEND_BIND_ADDR=0.0.0.0
FRONTEND_PORT=3000
BACKEND_BIND_ADDR=127.0.0.1
BACKEND_PORT=4000
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_ADDR=127.0.0.1
REDIS_PORT=6379
MAILPIT_BIND_ADDR=127.0.0.1
MAILPIT_WEB_PORT=8025

# Backend bind host bên trong container.
BACKEND_HOST=0.0.0.0

# Chỉ bật cho môi trường demo dùng dữ liệu mẫu. Production phải để false.
ENABLE_DEMO_SEED=false

# SMTP gửi mã xác nhận email và đặt lại mật khẩu. Bắt buộc nếu bật quên mật khẩu ở production.
# Ví dụ SMTP_PORT=587, SMTP_SECURE=false hoặc SMTP_PORT=465, SMTP_SECURE=true.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@genhub.local

# Máy chủ OCR quét ảnh sản phẩm (app iOS-OCR-Server chạy trên iPhone, cổng 8000).
# Có thể override trong app: Cài đặt → Máy chủ OCR.
# Example: OCR_SERVER_URL=http://192.168.1.50:8000
OCR_SERVER_URL=
